<Application x:Class="Grex365.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Grex365.App.Converters"
             xmlns:vm="clr-namespace:Grex365.App.ViewModels"
             xmlns:v="clr-namespace:Grex365.App.Views"
             xmlns:local="clr-namespace:Grex365.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToBrushConverter x:Key="BoolToBrushConverter" />
            <conv:BoolToOnOffConverter x:Key="BoolToOnOffConverter" />
            <conv:SeverityToBrushConverter x:Key="SeverityToBrushConverter" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <sys:String x:Key="IconFontFamily">Segoe Fluent Icons, Segoe MDL2 Assets</sys:String>

            <!-- Typography -->
            <Style x:Key="PageTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="PageSubtitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="Margin" Value="0,0,0,20" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="FieldLabelText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Opacity" Value="0.85" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="CaptionText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Opacity" Value="0.6" />
            </Style>

            <Style x:Key="MetricValueText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>

            <Style x:Key="MonoText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!-- Cards -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="MetricCard" TargetType="Border" BasedOn="{StaticResource Card}">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,12,12" />
            </Style>

            <!-- Page root -->
            <Style x:Key="PageRoot" TargetType="ScrollViewer">
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="Padding" Value="32,28,32,16" />
            </Style>

            <!-- Status pill (Ellipse) -->
            <Style x:Key="StatusDot" TargetType="Ellipse">
                <Setter Property="Width" Value="10" />
                <Setter Property="Height" Value="10" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Nav item: ListBoxItem styled with hover and selected -->
            <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="6,2" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="10,8">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True" />
                                        <Condition Property="IsMouseOver" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Sidebar background -->
            <Style x:Key="SidebarBorder" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,0" />
            </Style>

            <!-- DataTemplates -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <v:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
                <v:ConnectView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GroupsViewModel}">
                <v:GroupsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SharedMailboxViewModel}">
                <v:SharedMailboxView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AuditViewModel}">
                <v:AuditView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TenantHealthViewModel}">
                <v:TenantHealthView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                <v:UsersView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OffboardingViewModel}">
                <v:OffboardingView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OnboardingViewModel}">
                <v:OnboardingView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CertWizardViewModel}">
                <v:CertWizardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DomainCheckViewModel}">
                <v:DomainCheckView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

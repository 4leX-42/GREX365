<ui:FluentWindow x:Class="Grex365.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Grex365.App.ViewModels"
        xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
        mc:Ignorable="d"
        Title="GREX365 · Microsoft 365 toolkit"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GREX365" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Margin="12">
                        <ui:Button Content="Settings"
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding OpenSettingsCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavigationItem}">
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Glyph}"
                                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                               FontSize="16"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               FontSize="14" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ContentControl Grid.Row="0"
                                Content="{Binding CurrentPage}" />

                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              Background="Transparent" />

                <Border Grid.Row="2"
                        Margin="24,0,24,24"
                        CornerRadius="8"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Log"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <CheckBox Content="Info" IsChecked="{Binding ShowInfo}" Margin="0,0,8,0" />
                                <CheckBox Content="OK"   IsChecked="{Binding ShowOk}"   Margin="0,0,8,0" />
                                <CheckBox Content="Warn" IsChecked="{Binding ShowWarn}" Margin="0,0,8,0" />
                                <CheckBox Content="Err"  IsChecked="{Binding ShowError}" Margin="0,0,8,0" />
                                <CheckBox Content="Dbg"  IsChecked="{Binding ShowDebug}" />
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Content="Limpiar"
                                       Command="{Binding ClearLogCommand}" />
                        </Grid>
                        <ListBox ItemsSource="{Binding LogView}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LogEntry}">
                                    <Grid Margin="8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                   Opacity="0.6"
                                                   FontFamily="Cascadia Mono,Consolas" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Severity}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Source}"
                                                   Opacity="0.8" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="GREX365 · v0.1.0-alpha" Opacity="0.6" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>

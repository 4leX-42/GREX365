<ui:FluentWindow x:Class="Grex365.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Grex365.App.ViewModels"
        xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
        mc:Ignorable="d"
        Title="GREX365"
        Height="820" Width="1320"
        MinHeight="640" MinWidth="1100"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="GREX365 · Microsoft 365 toolkit" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SidebarBorder}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,18,16,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="{StaticResource IconFontFamily}"
                                       FontSize="22"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="GREX365" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="v0.2.0-alpha" FontSize="10" Opacity="0.55" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="10,8,10,12">
                        <ui:Button Content="Ajustes"
                                   Icon=""
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding OpenSettingsCommand}" />
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Margin="0,0,0,6" />

                    <ListBox ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigation}"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource NavListBoxItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavigationItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Glyph}"
                                               FontFamily="{StaticResource IconFontFamily}"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               FontSize="13" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="280" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <ContentControl Grid.Row="0"
                                Content="{Binding CurrentPage}" />

                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              ShowsPreview="True" />

                <Border Grid.Row="2"
                        Margin="24,0,24,16"
                        Style="{StaticResource Card}"
                        Padding="0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="16,12,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text=""
                                           FontFamily="{StaticResource IconFontFamily}"
                                           FontSize="14"
                                           Margin="0,0,8,0"
                                           Opacity="0.85"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Log de actividad"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center">
                                <CheckBox Content="Info" IsChecked="{Binding ShowInfo}" Margin="0,0,10,0" />
                                <CheckBox Content="OK"   IsChecked="{Binding ShowOk}"   Margin="0,0,10,0" />
                                <CheckBox Content="Warn" IsChecked="{Binding ShowWarn}" Margin="0,0,10,0" />
                                <CheckBox Content="Err"  IsChecked="{Binding ShowError}" Margin="0,0,10,0" />
                                <CheckBox Content="Dbg"  IsChecked="{Binding ShowDebug}" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       Content="Limpiar"
                                       Icon=""
                                       Command="{Binding ClearLogCommand}" />
                        </Grid>
                        <ListBox ItemsSource="{Binding LogView}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,0,8,8"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LogEntry}">
                                    <Grid Margin="8,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                   Opacity="0.55"
                                                   FontFamily="Cascadia Mono,Consolas"
                                                   FontSize="11" />
                                        <Border Grid.Column="1"
                                                CornerRadius="3"
                                                Padding="6,1"
                                                HorizontalAlignment="Left"
                                                Background="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}"
                                                Opacity="0.18" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Severity}"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Margin="6,1,0,0"
                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Source}"
                                                   Opacity="0.8"
                                                   FontSize="12" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
            <Grid Margin="16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding GraphConnected, Converter={StaticResource BoolToBrushConverter}}" />
                    <TextBlock Text="Graph" FontSize="12" Opacity="0.85" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse Style="{StaticResource StatusDot}"
                             Fill="{Binding ExchangeConnected, Converter={StaticResource BoolToBrushConverter}}" />
                    <TextBlock Text="Exchange Online" FontSize="12" Opacity="0.85" VerticalAlignment="Center" />
                </StackPanel>

                <Rectangle Grid.Column="2" Width="1" Margin="0,4,16,4"
                           Fill="{DynamicResource ControlStrokeColorDefaultBrush}" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12">
                    <Run Text="Tenant: " Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <Run Text="{Binding TenantDomain, FallbackValue=—}" />
                </TextBlock>

                <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12">
                    <Run Text="Cuenta: " Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <Run Text="{Binding Account, FallbackValue=—}" />
                </TextBlock>

                <TextBlock Grid.Column="5"
                           Text="GREX365 · v0.2.0-alpha"
                           Opacity="0.4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0" />

                <ui:Button Grid.Column="6"
                           Content="Desconectar"
                           Icon=""
                           Command="{Binding DisconnectAllCommand}" />
            </Grid>
        </Border>

        <ui:SnackbarPresenter x:Name="RootSnackbarPresenter"
                              Grid.Row="0"
                              Grid.RowSpan="3"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,16,24" />
    </Grid>
</ui:FluentWindow>

<ui:FluentWindow x:Class="Grex365.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Grex365.App.ViewModels"
        mc:Ignorable="d"
        Title="GREX365 · Settings"
        Height="640" Width="720"
        MinHeight="480" MinWidth="560"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" />

        <ScrollViewer Grid.Row="1" Margin="24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Preferencias"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="Método de conexión" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ComboBox SelectedValue="{Binding ConnectionMethod}"
                                  SelectedValuePath="Tag"
                                  Width="240"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="Certificado (app)" Tag="cert" />
                            <ComboBoxItem Content="Tradicional (UPN)" Tag="traditional" />
                        </ComboBox>

                        <TextBlock Text="Tenant esperado (ID)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding ExpectedTenantId, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="00000000-0000-0000-0000-000000000000"
                                    Margin="0,0,0,12" />

                        <TextBlock Text="Tenant esperado (dominio)" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding ExpectedTenantDomain, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="contoso.onmicrosoft.com"
                                    Margin="0,0,0,12" />

                        <CheckBox Content="Forzar tenant lock (rechazar conexión si no coincide)"
                                  IsChecked="{Binding EnforceTenantLock}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Certificado (App registration)"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="App ID" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding CertAppId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                        <TextBlock Text="Tenant ID" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding CertTenantId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                        <TextBlock Text="Organization" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding CertOrganization, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                        <TextBlock Text="Cert thumbprint" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ui:TextBox Text="{Binding CertThumbprint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ui:Button Content="Validar"
                                       Margin="0,0,8,0"
                                       Command="{Binding ValidateCertCommand}" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding CertStatusMessage}"
                                       Opacity="0.85" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding SaveStatus}"
                           Opacity="0.8"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />
                <ui:Button Content="Recargar"
                           Margin="0,0,8,0"
                           Command="{Binding LoadCommand}" />
                <ui:Button Content="Guardar"
                           Appearance="Primary"
                           Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>

<UserControl x:Class="Grex365.App.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:abs="clr-namespace:Grex365.Core.Abstractions;assembly=Grex365.Core"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Audit log" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Acciones registradas por el sink local (Ok/Warn/Error). JSONL por mes en %LOCALAPPDATA%\Grex365\audit\"
                   Opacity="0.7" Margin="0,0,0,16" />

        <Border Grid.Row="2" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mes:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.8" />
                <DatePicker Grid.Column="1" SelectedDate="{Binding Month}" Width="160" Margin="0,0,8,0" />
                <ui:Button Grid.Column="2" Content="Cargar" Command="{Binding LoadCommand}" Appearance="Primary" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.8" />
                    <ui:TextBox Text="{Binding SourceFilter, UpdateSourceTrigger=PropertyChanged}" Width="140" PlaceholderText="filtrar..." />
                    <TextBlock Text="Outcome:" VerticalAlignment="Center" Margin="12,0,6,0" Opacity="0.8" />
                    <ui:TextBox Text="{Binding OutcomeFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" PlaceholderText="OK/WARN/ERROR" />
                </StackPanel>

                <ui:Button Grid.Column="4" Content="Abrir carpeta" Margin="8,0,0,0" Command="{Binding OpenFolderCommand}" />
                <ui:ProgressRing Grid.Column="5" IsIndeterminate="True" Width="20" Height="20" Margin="8,0,0,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" CornerRadius="8" Padding="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Margin="12,8" Opacity="0.8" Text="{Binding StatusMessage}" />
                <DataGrid ItemsSource="{Binding Filtered}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource SubtleFillColorTertiaryBrush}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          VirtualizingPanel.IsVirtualizing="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                        <DataGridTextColumn Header="Actor"     Binding="{Binding Actor}"                                       Width="120" />
                        <DataGridTextColumn Header="Source"    Binding="{Binding Source}"                                      Width="120" />
                        <DataGridTextColumn Header="Outcome"   Binding="{Binding Outcome}"                                     Width="80" />
                        <DataGridTextColumn Header="Message"   Binding="{Binding Message}"                                     Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

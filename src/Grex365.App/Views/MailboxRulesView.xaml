<UserControl x:Class="Grex365.App.Views.MailboxRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Reglas buzón"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Out-of-Office (respuestas automáticas) · Forwarding (reenvío)"
                       Opacity="0.7"
                       Margin="0,0,0,16" />

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding Identity, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="UPN o SMTP del buzón" />
                    <ui:Button Grid.Column="1"
                               Content="Cargar"
                               Margin="8,0,0,0"
                               Command="{Binding LoadCommand}" />
                    <ui:ProgressRing Grid.Column="2"
                                     IsIndeterminate="True"
                                     Width="20" Height="20"
                                     Margin="8,0,0,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                </Grid>
            </Border>

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Out-of-Office (AutoReply)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Estado:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox ItemsSource="{Binding AutoReplyStates}"
                                  SelectedItem="{Binding AutoReplyState}"
                                  Width="160" />
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Mensaje interno" Opacity="0.7" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding InternalMessage, UpdateSourceTrigger=PropertyChanged}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Height="100"
                                        VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Mensaje externo" Opacity="0.7" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding ExternalMessage, UpdateSourceTrigger=PropertyChanged}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        Height="100"
                                        VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="StartTime (sólo si Scheduled)" Opacity="0.7" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding StartTime}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="EndTime (sólo si Scheduled)" Opacity="0.7" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding EndTime}" />
                        </StackPanel>
                    </Grid>

                    <ui:Button Content="Aplicar AutoReply"
                               Appearance="Primary"
                               Command="{Binding ApplyAutoReplyCommand}"
                               HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Forwarding (reenvío)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CurrentForwardingDisplay}" Opacity="0.7" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding ForwardingSmtp, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="destino@dominio.com" />
                        <CheckBox Grid.Column="1"
                                  Content="Entregar también al buzón"
                                  IsChecked="{Binding DeliverToMailboxAndForward}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0" />
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Aplicar reenvío"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"
                                   Command="{Binding ApplyForwardingCommand}" />
                        <ui:Button Content="Quitar reenvío"
                                   Command="{Binding ClearForwardingCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="Permisos de calendario" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding CalendarPrincipal, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="UPN o SMTP del concesionario" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CalendarAccessOptions}"
                                  SelectedItem="{Binding CalendarAccess}"
                                  Margin="8,0,0,0" />
                        <ui:Button Grid.Column="2"
                                   Content="Aplicar / Actualizar"
                                   Appearance="Primary"
                                   Margin="8,0,0,0"
                                   Command="{Binding ApplyCalendarPermissionCommand}" />
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Permisos actuales"
                                   FontWeight="SemiBold"
                                   Opacity="0.8" />
                        <ui:Button Grid.Column="1"
                                   Content="Quitar seleccionado"
                                   Command="{Binding RemoveCalendarPermissionCommand}" />
                    </Grid>

                    <ListBox ItemsSource="{Binding CalendarPermissions}"
                             SelectedItem="{Binding SelectedCalendarPermission}"
                             Background="Transparent"
                             BorderThickness="0"
                             MaxHeight="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CalendarPermissionEntry}">
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Principal}" />
                                    <TextBlock Grid.Column="1" Text="{Binding AccessRights}" Opacity="0.8" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Opacity="0.8" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

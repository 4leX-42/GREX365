<UserControl x:Class="Grex365.App.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Usuarios"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Buscar, ver y administrar cuentas (habilitar/deshabilitar, quitar licencias)"
                   Opacity="0.7"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Margin="0,0,8,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Buscar" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Nombre, UPN o email" />
                        <ui:Button Grid.Column="1"
                                   Content="Buscar"
                                   Margin="8,0,0,0"
                                   Command="{Binding SearchCommand}" />
                        <ui:Button Grid.Column="2"
                                   Content="Cancelar"
                                   Margin="8,0,0,0"
                                   Command="{Binding CancelCommand}" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Users}"
                             SelectedItem="{Binding SelectedUser}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:UserSummary}">
                                <StackPanel Margin="4,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                                 Fill="{Binding AccountEnabled, Converter={StaticResource BoolToBrushConverter}}" />
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UserPrincipalName}" Opacity="0.7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Margin="8,0,0,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding SelectedUser.DisplayName, FallbackValue='Selecciona un usuario'}"
                               FontWeight="SemiBold"
                               FontSize="18"
                               Margin="0,0,0,8" />

                    <Grid Grid.Row="1" Margin="0,0,0,8"
                          Visibility="{Binding SelectedUser, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="UPN" Opacity="0.7" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedUser.UserPrincipalName}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mail" Opacity="0.7" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUser.Mail}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cuenta" Opacity="0.7" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SelectedUser.AccountEnabled, Converter={StaticResource BoolToOnOffConverter}}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Licencias" Opacity="0.7" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedUser.AssignedLicenseCount}" />
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
                        <ui:Button Content="Habilitar"
                                   Margin="0,0,8,0"
                                   Command="{Binding EnableCommand}" />
                        <ui:Button Content="Deshabilitar"
                                   Margin="0,0,8,0"
                                   Command="{Binding DisableCommand}" />
                        <ui:Button Content="Quitar licencias"
                                   Margin="0,0,8,0"
                                   Command="{Binding RemoveLicensesCommand}" />
                        <ui:Button Content="Bulk CSV..."
                                   Margin="0,0,8,0"
                                   Command="{Binding ImportBulkCsvCommand}" />
                        <ui:Button Content="Exportar bulk..."
                                   Margin="0,0,8,0"
                                   Command="{Binding ExportBulkResultsCommand}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Opacity="0.8" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Pertenece a" FontWeight="SemiBold" Margin="0,8,0,4" />
                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding Memberships}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GroupSummary}">
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Mail}" Opacity="0.7" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding GroupKind}" Opacity="0.8" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

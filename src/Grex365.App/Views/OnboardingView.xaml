<UserControl x:Class="Grex365.App.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Onboarding"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Crear usuario · asignar licencias · añadir a grupos"
                       Opacity="0.7"
                       Margin="0,0,0,16" />

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre completo" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,0,8" />
                    <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Ana Garcia" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="UPN" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,0,8" />
                    <ui:TextBox Grid.Row="0" Grid.Column="4" Text="{Binding Upn, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="ana.garcia@contoso.com" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alias (MailNickname)" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,0,8" />
                    <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MailNickname, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="(opcional, deriva del UPN)" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="UsageLocation (ISO-2)" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,0,8" />
                    <ui:TextBox Grid.Row="1" Grid.Column="4" Text="{Binding UsageLocation, UpdateSourceTrigger=PropertyChanged}" MaxLength="2" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Password inicial" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,0,8" />
                    <ui:PasswordBox Grid.Row="2" Grid.Column="1" Password="{Binding InitialPassword, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Mínimo 8 caracteres" Margin="0,0,0,8" />
                    <CheckBox Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2"
                              Content="Forzar cambio en primer login"
                              IsChecked="{Binding ForceChangePassword}"
                              VerticalAlignment="Center" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Licencias (SKU)" VerticalAlignment="Center" Opacity="0.8" Margin="0,8,0,8" />
                    <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Cargar SKUs" Command="{Binding LoadSkusCommand}" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableSkus}"
                                  SelectedItem="{Binding SelectedSku}"
                                  DisplayMemberPath="Display"
                                  Margin="0,0,8,0" />
                        <ui:Button Grid.Column="2" Content="Añadir" Command="{Binding AddSelectedSkuCommand}" />
                    </Grid>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Licencias a asignar" VerticalAlignment="Top" Opacity="0.8" Margin="0,4,0,8" />
                    <ItemsControl Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                                  ItemsSource="{Binding SelectedSkus}"
                                  Margin="0,4,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SkuInfo}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Display}" />
                                    <ui:Button Grid.Column="1"
                                               Content="Quitar"
                                               Command="{Binding DataContext.RemoveSkuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Grupos (uno por línea)" VerticalAlignment="Top" Opacity="0.8" Margin="0,4,0,0" />
                    <ui:TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4"
                                Text="{Binding GroupsText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="80"
                                VerticalScrollBarVisibility="Auto"
                                PlaceholderText="email del grupo, displayName o id (uno por línea)" />
                </Grid>
            </Border>

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Ejecutar onboarding"
                               Appearance="Primary"
                               Margin="0,0,8,0"
                               Command="{Binding RunCommand}" />
                    <ui:Button Content="Cancelar"
                               Margin="0,0,8,0"
                               Command="{Binding CancelCommand}" />
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="20" Height="20"
                                     Margin="8,0,8,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding StatusMessage}"
                               Opacity="0.8" />
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    Visibility="{Binding Steps.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Pasos" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:OnboardingStep}">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding Status}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Opacity="0.7" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="Grex365.App.Views.GroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Grupos y DLs"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Buscar grupos M365/DL y gestionar miembros"
                   Opacity="0.7"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Margin="0,0,8,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Buscar grupo" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Nombre o email del grupo" />
                        <ui:Button Grid.Column="1"
                                   Content="Buscar"
                                   Margin="8,0,0,0"
                                   Command="{Binding SearchCommand}" />
                        <ui:ProgressRing IsIndeterminate="True"
                                         Grid.Column="1"
                                         Width="16" Height="16"
                                         Margin="0,0,8,0"
                                         HorizontalAlignment="Right"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GroupSummary}">
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Opacity="0.7">
                                        <TextBlock Text="{Binding Mail}" />
                                        <TextBlock Text=" · " />
                                        <TextBlock Text="{Binding GroupKind}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Margin="8,0,0,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SelectedGroup.DisplayName, FallbackValue='Selecciona un grupo'}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Content="Eliminar seleccionado"
                                       Margin="0,0,8,0"
                                       Command="{Binding RemoveSelectedMemberCommand}" />
                            <ui:Button Content="Exportar miembros..."
                                       Command="{Binding ExportMembersCommand}" />
                        </StackPanel>
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Members}"
                             SelectedItem="{Binding SelectedMember}"
                             Background="Transparent"
                             BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GroupMember}">
                                <Grid Margin="4,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName, FallbackValue=—}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Mail, FallbackValue=—}"
                                               Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Text="Añadir miembros (uno por línea, email o id)"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4" />
                    <ui:TextBox Grid.Row="3"
                                Text="{Binding NewMembersText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="80"
                                VerticalScrollBarVisibility="Auto" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Añadir"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"
                                   Command="{Binding AddMembersCommand}" />
                        <ui:Button Content="Importar CSV..."
                                   Margin="0,0,8,0"
                                   Command="{Binding ImportCsvCommand}" />
                        <ui:Button Content="Exportar resultados..."
                                   Margin="0,0,8,0"
                                   Command="{Binding ExportResultsCommand}" />
                        <ui:Button Content="Cancelar"
                                   Margin="0,0,8,0"
                                   Command="{Binding CancelCommand}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Opacity="0.8" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" CornerRadius="8" Margin="0,12,0,0" Padding="12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Visibility="{Binding LastAddResults.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel>
                <TextBlock Text="Últimos resultados" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding LastAddResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:AddMemberResult}">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Input}" />
                                <TextBlock Grid.Column="1" Text="{Binding Status}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="{Binding Detail}" Opacity="0.7" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

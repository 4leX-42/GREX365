<UserControl x:Class="Grex365.App.Views.OffboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:Grex365.Core.Models;assembly=Grex365.Core"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Offboarding"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Deshabilitar cuenta, quitar licencias y convertir buzón a compartido"
                       Opacity="0.7"
                       Margin="0,0,0,16" />

            <Border CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel>
                    <TextBlock Text="UPN del usuario" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ui:TextBox Text="{Binding Upn, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="leaver@contoso.com"
                                Margin="0,0,0,12" />

                    <CheckBox Content="Deshabilitar cuenta (AccountEnabled=false)"
                              IsChecked="{Binding DisableAccount}"
                              Margin="0,0,0,4" />
                    <CheckBox Content="Quitar todas las licencias asignadas"
                              IsChecked="{Binding RemoveLicenses}"
                              Margin="0,0,0,4" />
                    <CheckBox Content="Convertir buzón a SharedMailbox (libera licencia E3/E5)"
                              IsChecked="{Binding ConvertMailboxToShared}" />

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <ui:Button Content="Ejecutar offboarding"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"
                                   Command="{Binding RunCommand}" />
                        <ui:Button Content="Cancelar"
                                   Margin="0,0,8,0"
                                   Command="{Binding CancelCommand}" />
                        <ui:ProgressRing IsIndeterminate="True"
                                         Width="20" Height="20"
                                         Margin="8,0,8,0"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    Visibility="{Binding Steps.Count, Converter={StaticResource CountToVisibilityConverter}, FallbackValue=Collapsed}">
                <StackPanel>
                    <TextBlock Text="Pasos" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:OffboardingStep}">
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding Status}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Opacity="0.7" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

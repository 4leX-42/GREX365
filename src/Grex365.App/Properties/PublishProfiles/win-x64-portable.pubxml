<?xml version="1.0" encoding="utf-8"?>
<!--
Perfil de publicación: ejecutable único portable (self-contained, sin instalador).

Uso:
    dotnet publish src/Grex365.App/Grex365.App.csproj `
        -c Release -p:PublishProfile=win-x64-portable

Genera Grex365.App.exe en bin/Release/net10.0-windows/win-x64/publish/.
Tamaño esperado: ~150-200 MB (incluye runtime .NET 10 + Wpf.Ui + Graph SDK).
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>bin\Release\net10.0-windows\win-x64\publish\</PublishDir>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <DebugType>embedded</DebugType>
  </PropertyGroup>
</Project>
